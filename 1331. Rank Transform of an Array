class Solution {
    public int[] arrayRankTransform(int[] arr) {
        int []a= arr.clone();
        Arrays.sort(a);
        int []ab=new int[arr.length];
        HashMap<Integer,Integer>hm=new HashMap<>();
        int rank=1;
        for(int num: a){
           if(!hm.containsKey(num)){
               hm.put(num,rank++);
           }
        }

       for(int i=0;i<arr.length;i++){
            ab[i]=hm.get(arr[i]);
        }return ab;
    }
} 

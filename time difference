class Solution {
    public int secondsBetweenTimes(String startTime, String endTime) {

        int start =
                ((startTime.charAt(0) - '0') * 10 + (startTime.charAt(1) - '0')) * 3600 +
                ((startTime.charAt(3) - '0') * 10 + (startTime.charAt(4) - '0')) * 60 +
                ((startTime.charAt(6) - '0') * 10 + (startTime.charAt(7) - '0'));

        int end =
                ((endTime.charAt(0) - '0') * 10 + (endTime.charAt(1) - '0')) * 3600 +
                ((endTime.charAt(3) - '0') * 10 + (endTime.charAt(4) - '0')) * 60 +
                ((endTime.charAt(6) - '0') * 10 + (endTime.charAt(7) - '0'));

        return Math.abs(start - end);
    }
}

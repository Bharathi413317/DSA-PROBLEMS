class Solution {

    public long sumAndMultiply(int n) {
          String s = String.valueOf(n);
          StringBuilder sb=new StringBuilder();
          long sum=0;
          if(n==0) return 0;
          for(int i=0;i<s.length();i++){
                 if(s.charAt(i)-'0'!=0){
                    sb.append(s.charAt(i));
                    sum+=s.charAt(i)-'0';
                 }
          }long num =(long)Integer.parseInt(sb.toString());
          return sum*num;
    }
}

class Solution {
    public int numberOfAlternatingGroups(int[] colors) {
        int count=0;
        int n=colors.length;
        for(int i=0;i<colors.length;i++){
            int first=i;
            int second=(i+1)%n;
            int third=(i+2)%n;
            if(colors[first]!=colors[second] && colors[second]!=colors[third]){
                count++;
            }
        }return count;
    }
}

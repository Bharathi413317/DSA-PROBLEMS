class Solution {
    public int[][] updateMatrix(int[][] mat) {

        int m = mat.length;
        int n = mat[0].length;

        int[][] arr = new int[m][n];
        int INF = 100000;

     
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (mat[i][j] == 0)
                    arr[i][j] = 0;
                else
                    arr[i][j] = INF;
            }
        }

        boolean changed;

        do {
            changed = false;

            for (int i = 0; i < m; i++) {
                for (int j = 0; j < n; j++) {

                    if (arr[i][j] == 0)
                        continue;

                    int old = arr[i][j];

                    if (i > 0)
                        arr[i][j] = Math.min(arr[i][j], arr[i - 1][j] + 1);

                    if (i < m - 1)
                        arr[i][j] = Math.min(arr[i][j], arr[i + 1][j] + 1);

                    if (j > 0)
                        arr[i][j] = Math.min(arr[i][j], arr[i][j - 1] + 1);

                    if (j < n - 1)
                        arr[i][j] = Math.min(arr[i][j], arr[i][j + 1] + 1);

                    if (old != arr[i][j])
                        changed = true;
                }
            }

        } while (changed);

        return arr;
    }
}
